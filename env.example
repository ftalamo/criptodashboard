# ═══════════════════════════════════════════════════════════
#  .env — Credenciales privadas del Trading Scanner
#
#  INSTRUCCIONES:
#  1. Renombra este archivo de .env.example a .env
#  2. Rellena tus credenciales de Binance
#  3. Nunca subas .env a git (ya está en .gitignore)
# ═══════════════════════════════════════════════════════════

# ── Binance API ────────────────────────────────────────────
# Obtén tus keys en: https://www.binance.com/es/my/settings/api-management
# Permisos necesarios: solo lectura (Read Info) — NO habilitar trading ni retiros

BINANCE_API_KEY=tu_api_key_aqui
BINANCE_API_SECRET=tu_api_secret_aqui

# ── Capital disponible para cálculo de órdenes ─────────────
# Este valor se usa para calcular cuánto USDT deployar por trade

USDT_AVAILABLE=127.55
