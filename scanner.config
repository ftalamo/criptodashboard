# ═══════════════════════════════════════════════════════════
#  scanner.config — Configuración del Trading Scanner
#  Editar este archivo para personalizar el portfolio,
#  intervalos y comportamiento del servidor.
#  No requiere reiniciar el servidor — se recarga en cada scan.
# ═══════════════════════════════════════════════════════════


# ── Portfolio por defecto ──────────────────────────────────
# Símbolos que aparecen en el dashboard al abrir.
# Formato: SYMBOL (sin USDT) separados por coma.
# Ejemplo: BTC, ETH, LTH,XPR,DOGE

PORTFOLIO = BTC, ETH, LTH,XPR,DOGE


# ── Intervalos disponibles ─────────────────────────────────
# Todos los timeframes que el sistema puede manejar.
# El dashboard mostrará estos como opciones seleccionables.
# Valores válidos de Binance: 1m, 3m, 5m, 15m, 30m, 1h, 2h, 4h, 6h, 8h, 12h, 1d, 3d, 1w, 1M

INTERVALS_AVAILABLE = 3m, 5m, 15m, 1h, 4h, 12h, 1d,3d,1w,1M


# ── Intervalos por defecto ─────────────────────────────────
# Subset de INTERVALS_AVAILABLE que viene preseleccionado.
# Deben ser un subconjunto de INTERVALS_AVAILABLE.

INTERVALS_DEFAULT = 15m, 1h, 4h, 12h, 1d


# ── Servidor ───────────────────────────────────────────────
SERVER_HOST = 127.0.0.1
SERVER_PORT = 8000
